# Database (Railway Postgres)
DATABASE_URL=                       # TODO:ENV postgresql://user:pass@host:port/dbname

# Auth.js
AUTH_SECRET=                        # TODO:ENV openssl rand -base64 32
AUTH_URL=http://localhost:3000      # TODO:ENV https://ralph.world in production
AUTH_TRUST_HOST=true                # Required when running behind Railway proxy

# OAuth providers
AUTH_GOOGLE_ID=                     # TODO:ENV Google OAuth client ID
AUTH_GOOGLE_SECRET=                 # TODO:ENV Google OAuth client secret
# AUTH_APPLE_ID=                    # Post-MVP: Apple OAuth service ID
# AUTH_APPLE_SECRET=                # Post-MVP: Apple OAuth private key

# Broadcaster (Ralph TV)
BROADCASTER_BACKEND_URL=            # TODO:ENV Ralph TV backend Railway URL (server-side only)
NEXT_PUBLIC_BROADCASTER_RELAY_URL=  # TODO:ENV Ralph TV relay HLS URL (read by LivePlayer in client)
BROADCASTER_SERVICE_TOKEN=          # TODO:ENV X-Service-Token for Broadcaster API auth

# Shopify
SHOPIFY_STOREFRONT_URL=             # TODO:ENV https://store.myshopify.com/api/2024-01/graphql.json
SHOPIFY_STOREFRONT_TOKEN=           # TODO:ENV Shopify Storefront API token
SHOPIFY_WEBHOOK_SECRET=             # TODO:ENV For HMAC verification of Shopify webhooks
SHOPIFY_SUBSCRIPTION_VARIANT_ID=    # TODO:ENV gid://shopify/ProductVariant/... for the £3/month subscription
# Admin API (Task 1.6 customer auto-create + Phase 3 synthetic orders)
SHOPIFY_STORE_DOMAIN=               # TODO:ENV store.myshopify.com (no protocol)
SHOPIFY_ADMIN_ACCESS_TOKEN=         # TODO:ENV shpat_... Admin API access token
SHOPIFY_ADMIN_API_VERSION=          # TODO:ENV optional, defaults to 2024-01

# Resend (transactional email — Task 1.4)
RESEND_API_KEY=                     # TODO:ENV re_... Resend API key
RESEND_FROM=                        # TODO:ENV optional, defaults to Ralph.world <hello@ralph.world>
RESEND_WEBHOOK_SECRET=              # TODO:ENV whsec_... Svix webhook secret

# Stripe (Phase 2 — subscription billing)
STRIPE_PUBLISHABLE_KEY=             # TODO:ENV pk_test_... or pk_live_...
STRIPE_SECRET_KEY=                  # TODO:ENV sk_test_... or sk_live_...
STRIPE_PRICE_ID=                    # TODO:ENV price_... for £3/mo Ralph Magazine Subscription
STRIPE_WEBHOOK_SECRET=              # TODO:ENV whsec_... Stripe webhook signing secret

# Revalidation (shared secret with CMS for on-demand rebuilds)
REVALIDATE_SECRET=                  # TODO:ENV openssl rand -base64 32

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=             # TODO:ENV https://<key>@<host>.ingest.sentry.io/<project>
SENTRY_AUTH_TOKEN=                  # TODO:ENV source-map upload token (build-time only)
# Note: wizard also writes a .env.sentry-build-plugin file (gitignored) holding
# the same token for local builds. Set SENTRY_AUTH_TOKEN in Railway.

# App
NEXT_PUBLIC_APP_URL=                # TODO:ENV https://ralph.world (or Railway URL in staging)

# Internal service-to-service auth — Task 3.9. CMS calls ralph-world to
# trigger the magazine fulfilment batch job. Shared bearer token; must
# match INTERNAL_API_TOKEN on ralph-cms.
INTERNAL_API_TOKEN=                 # TODO:ENV openssl rand -base64 32
